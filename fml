#!/bin/bash
# fml — Fix My Laptop
# A lightweight system maintenance tool for low-spec Linux machines
# https://github.com/Melangert/Fix-My-Laptop-FML-
# License: MIT

set -uo pipefail

VERSION="1.1.1"
SCRIPT_NAME="fml"

## ── Color support ──────────────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ "${NO_COLOR:-}" == "" ]]; then
    RED=$'\033[0;31m'; YELLOW=$'\033[1;33m'; GREEN=$'\033[0;32m'
    CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; RESET=$'\033[0m'
else
    RED=''; YELLOW=''; GREEN=''; CYAN=''; BOLD=''; RESET=''
fi

# ── Helpers ────────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}→${RESET} $*"; }
success() { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
error()   { echo -e "${RED}✖${RESET}  $*" >&2; }
header()  { echo -e "\n${BOLD}━━ $* ━━${RESET}"; }

pause() {
    echo ""
    read -rp "Press Enter to continue..."
}

require_command() {
    command -v "$1" >/dev/null 2>&1
}

run_sudo() {
    if require_command sudo; then
        sudo "$@"
    else
        error "sudo not available — skipping: $*"
        return 1
    fi
}

confirm() {
    local prompt="${1:-Are you sure?}"
    local answer
    read -rp "$(echo -e "${YELLOW}?${RESET}  ${prompt} [y/N] ")" answer
    [[ "$answer" =~ ^[Yy]$ ]]
}

# ── Status ─────────────────────────────────────────────────────────────────────
status() {
    header "System Status"

    info "Load averages (1m / 5m / 15m):"
    awk '{print "   " $1 " / " $2 " / " $3}' /proc/loadavg

    info "Memory:"
    free -h | awk '
        /^Mem:/  { printf "   Used: %s / %s\n", $3, $2 }
        /^Swap:/ { if ($2 != "0B") printf "   Swap: %s / %s\n", $3, $2 }
    '

    info "Disk (/):"
    df -h / | awk 'NR==2 { printf "   Used: %s / %s (%s)\n", $3, $2, $5 }'

    info "Uptime:"
    uptime -p 2>/dev/null || uptime
}

# ── Top processes ──────────────────────────────────────────────────────────────
topcpu() {
    header "Top Resource-Heavy Processes"

    info "By CPU:"
    ps -eo pid,comm,%cpu,%mem --sort=-%cpu 2>/dev/null | head -11 | \
        awk 'NR==1 { printf "   %-8s %-22s %5s %5s\n", $1,$2,$3,$4; next }
                   { printf "   %-8s %-22s %5s %5s\n", $1,$2,$3,$4 }'

    echo ""
    info "By Memory:"
    ps -eo pid,comm,%cpu,%mem --sort=-%mem 2>/dev/null | head -6 | \
        awk 'NR==1 { printf "   %-8s %-22s %5s %5s\n", $1,$2,$3,$4; next }
                   { printf "   %-8s %-22s %5s %5s\n", $1,$2,$3,$4 }'
}

# ── Clean ──────────────────────────────────────────────────────────────────────
clean() {
    local dry_run=false
    [[ "${1:-}" == "--dry-run" ]] && dry_run=true

    header "System Cleanup"

    if $dry_run; then
        echo -e "  ${YELLOW}DRY RUN — nothing will be changed.${RESET}"
    else
        echo "  Removes unused packages, old logs, and cache files."
        echo "  Your personal files and app data are never touched."
    fi
    echo ""

    # ── Size helpers ──
    dir_size_mb() {
        local path="$1"
        [[ -e "$path" ]] || { echo 0; return; }
        du -sm "$path" 2>/dev/null | awk '{print $1}' || echo 0
    }

    fmt_mb() {
        local mb="$1"
        if (( mb >= 1024 )); then
            awk "BEGIN{printf \"%.1f GB\", ${mb}/1024}"
        elif (( mb == 0 )); then
            echo "0 MB"
        else
            echo "${mb} MB"
        fi
    }

    # ── Collect estimates ──
    local apt_mb=0 dnf_mb=0 pacman_mb=0 flatpak_mb=0
    local thumb_mb=0 browser_mb=0 tmp_mb=0 journal_mb=0
    local total_mb=0

    if require_command apt-get; then
        apt_mb=$(dir_size_mb /var/cache/apt/archives)
    fi
    if require_command dnf; then
        dnf_mb=$(dir_size_mb /var/cache/dnf)
    fi
    if require_command pacman; then
        pacman_mb=$(dir_size_mb /var/cache/pacman/pkg)
    fi
    if require_command flatpak; then
        flatpak_mb=$(dir_size_mb /var/lib/flatpak/runtime)
    fi

    thumb_mb=$(dir_size_mb "${HOME}/.cache/thumbnails")

    local browser_dirs=(
        "${HOME}/.cache/google-chrome/Default/Cache"
        "${HOME}/.cache/chromium/Default/Cache"
        "${HOME}/.cache/mozilla/firefox"
    )
    for d in "${browser_dirs[@]}"; do
        local bm
        bm=$(dir_size_mb "$d")
        (( browser_mb += bm ))
    done

    tmp_mb=$(find /tmp -maxdepth 1 -user "$USER" -not -name "." \
        -exec du -sm {} + 2>/dev/null | awk '{s+=$1}END{print s+0}')

    if require_command journalctl; then
        journal_mb=$(dir_size_mb /var/log/journal)
    fi

    total_mb=$(( apt_mb + dnf_mb + pacman_mb + flatpak_mb + thumb_mb + browser_mb + tmp_mb + journal_mb ))

    # ── Dry run: print breakdown and exit ──
    if $dry_run; then
        header "Cleanup Breakdown"
        local -a rows=()
        (( apt_mb     > 0 )) && rows+=("APT cache|${apt_mb}")
        (( dnf_mb     > 0 )) && rows+=("DNF cache|${dnf_mb}")
        (( pacman_mb  > 0 )) && rows+=("Pacman cache|${pacman_mb}")
        (( flatpak_mb > 0 )) && rows+=("Flatpak runtimes|${flatpak_mb}")
        (( thumb_mb   > 0 )) && rows+=("Thumbnails|${thumb_mb}")
        (( browser_mb > 0 )) && rows+=("Browser caches|${browser_mb}")
        (( tmp_mb     > 0 )) && rows+=("Temp files (/tmp)|${tmp_mb}")
        (( journal_mb > 0 )) && rows+=("Journal logs|${journal_mb}")

        if (( ${#rows[@]} == 0 )); then
            info "Nothing significant found to clean."
            return 0
        fi

        for row in "${rows[@]}"; do
            local label="${row%%|*}"
            local mb="${row##*|}"
            printf "  %-25s %s\n" "$label" "~$(fmt_mb "$mb")"
        done

        echo ""
        printf "  %-25s %s\n" "$(echo -e "${BOLD}Total${RESET}")" "$(echo -e "${BOLD}~$(fmt_mb "$total_mb")${RESET}")"
        echo ""
        info "Run 'fml clean' to apply these changes."
        return 0
    fi

    # ── Real cleanup (unchanged logic) ──
    confirm "Proceed with cleanup?" || { info "Cleanup cancelled."; return 0; }
    echo ""

    if require_command apt-get; then
        info "Cleaning APT packages..."
        run_sudo apt-get autoremove -y -q 2>/dev/null && \
        run_sudo apt-get clean -q 2>/dev/null && \
        success "APT cleaned."
    fi

    if require_command dnf; then
        info "Cleaning DNF packages..."
        run_sudo dnf autoremove -y -q 2>/dev/null && success "DNF cleaned."
    fi

    if require_command pacman; then
        info "Cleaning Pacman cache..."
        if require_command paccache; then
            run_sudo paccache -rk1 2>/dev/null && success "Pacman cache trimmed (kept 1 version)."
        else
            run_sudo pacman -Sc --noconfirm 2>/dev/null && success "Pacman cache cleared."
        fi
    fi

    if require_command zypper; then
        info "Cleaning Zypper packages..."
        run_sudo zypper clean -a 2>/dev/null && success "Zypper cleaned."
    fi

    if require_command flatpak; then
        info "Removing unused Flatpak runtimes..."
        flatpak uninstall --unused -y 2>/dev/null && success "Flatpak cleaned."
    fi

    if require_command snap; then
        info "Removing old Snap revisions..."
        snap list --all 2>/dev/null | awk '/disabled/ {print $1, $3}' | \
            while read -r snapname revision; do
                run_sudo snap remove "$snapname" --revision="$revision" 2>/dev/null
            done
        success "Old Snap revisions removed."
    fi

    if [[ -d "${HOME}/.cache/thumbnails" ]]; then
        info "Clearing thumbnail cache..."
        rm -rf "${HOME}/.cache/thumbnails"/* 2>/dev/null
        success "Thumbnail cache cleared."
    fi

    for d in "${browser_dirs[@]}"; do
        if [[ -d "$d" ]]; then
            info "Clearing $(basename "$(dirname "$d")") cache..."
            rm -rf "${d:?}"/* 2>/dev/null
            success "Done."
        fi
    done

    info "Removing your temp files from /tmp..."
    find /tmp -maxdepth 1 -user "$USER" -not -name "." \
        -exec rm -rf {} + 2>/dev/null || true
    success "Temp files cleaned."

    if require_command journalctl; then
        info "Trimming system journal (keeping 7 days)..."
        run_sudo journalctl --vacuum-time=7d 2>/dev/null && success "Journal trimmed."
    fi

    echo ""
    success "Cleanup complete."
}

# ── Power toggle ───────────────────────────────────────────────────────────────
boost() {
    header "Power Profile Toggle"

    local current="" method=""

    if require_command powerprofilesctl; then
        current=$(powerprofilesctl get 2>/dev/null || echo "unknown")
        info "Current profile: ${BOLD}${current}${RESET}"
        if [[ "$current" == "performance" ]]; then
            powerprofilesctl set power-saver 2>/dev/null && method="powerprofilesctl"
            success "Switched to power-saver — less heat, better battery life."
        else
            powerprofilesctl set performance 2>/dev/null && method="powerprofilesctl"
            success "Switched to performance mode."
            warn "Run 'fml boost' again to switch back to power-saver when done."
        fi

    elif require_command tuned-adm; then
        current=$(tuned-adm active 2>/dev/null | awk '{print $NF}' || echo "unknown")
        info "Current profile: ${BOLD}${current}${RESET}"
        if [[ "$current" == *"throughput"* || "$current" == *"performance"* ]]; then
            run_sudo tuned-adm profile powersave 2>/dev/null && method="tuned-adm"
            success "Switched to powersave mode."
        else
            run_sudo tuned-adm profile throughput-performance 2>/dev/null && method="tuned-adm"
            success "Switched to performance mode."
            warn "Run 'fml boost' again to switch back when done."
        fi

    elif require_command cpupower; then
        current=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "unknown")
        info "Current governor: ${BOLD}${current}${RESET}"
        if [[ "$current" == "performance" ]]; then
            run_sudo cpupower frequency-set -g powersave 2>/dev/null && method="cpupower"
            success "Switched to powersave mode."
        else
            run_sudo cpupower frequency-set -g performance 2>/dev/null && method="cpupower"
            success "Switched to performance mode."
            warn "Run 'fml boost' again to switch back when done."
        fi

    elif [[ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]]; then
        current=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "unknown")
        info "Current governor: ${BOLD}${current}${RESET}"
        warn "No tool available to change it — install cpupower to enable toggling."
        return 0

    else
        warn "No power profile control found on this system."
        info "Your kernel likely manages CPU performance automatically."
        return 0
    fi

    if [[ -z "$method" ]]; then
        error "Failed to switch power profile — try running with sudo."
        return 1
    fi
}
# ── Shared metrics (used by health + fix) ─────────────────────────────────────
gather_metrics() {
    # Just 
    local mem_used mem_total swap_used swap_total

    METRIC_LOAD1=$(awk '{print $1}' /proc/loadavg)
    METRIC_NCPU=$(nproc 2>/dev/null || echo 1)
    # Integer version of load for comparisons like (( load_int > ncpu ))
    METRIC_LOAD_INT=$(echo "$METRIC_LOAD1" | awk '{printf "%.0f", $1}')

    mem_used=$(free | awk '/^Mem:/{print $3}')
    mem_total=$(free | awk '/^Mem:/{print $2}')
    METRIC_MEM_PCT=$(awk "BEGIN{printf \"%.0f\", ${mem_used}/${mem_total}*100}")

    METRIC_DISK_PCT=$(df / | awk 'NR==2{gsub(/%/,"",$5); print $5}')

    swap_used=$(free | awk '/^Swap:/{print $3}')
    swap_total=$(free | awk '/^Swap:/{print $2}')
    # Swap might not exist — default to 0 if total is 0
    if [[ -n "$swap_total" && "$swap_total" -gt 0 ]]; then
        METRIC_SWAP_PCT=$(awk "BEGIN{printf \"%.0f\", ${swap_used}/${swap_total}*100}")
    else
        METRIC_SWAP_PCT=0
    fi
}

# ── Auto-fix ───────────────────────────────────────────────────────────────────
fix() {
    header "Auto-Fix"
    echo "  Checks your system and offers to fix each problem found."
    echo ""

    # Gather all metrics first into METRIC_ variables
    gather_metrics

    local fixed=0
    local skipped=0

    # ── Check 1: High RAM ──
    # If RAM over 85%, offer to run clean
    if (( METRIC_MEM_PCT > 85 )); then
        warn "RAM usage is ${METRIC_MEM_PCT}% — that's high."
        info "Suggested fix: run cleanup to free cache and temp files."
        if confirm "Run cleanup now?"; then
            clean
            (( fixed++ ))
        else
            (( skipped++ ))
        fi
        echo ""
    fi

    # ── Check 2: High disk ──
    # If disk over 85%, offer to run clean
    if (( METRIC_DISK_PCT > 85 )); then
        warn "Disk usage is ${METRIC_DISK_PCT}% — getting full."
        info "Suggested fix: run cleanup to recover disk space."
        if confirm "Run cleanup now?"; then
            clean
            (( fixed++ ))
        else
            (( skipped++ ))
        fi
        echo ""
    fi

    # ── Check 3: High load ──
    # If load exceeds 2x CPU count, offer to switch to power-saver
    # to reduce background pressure
    if (( METRIC_LOAD_INT > METRIC_NCPU * 2 )); then
        warn "Load is ${METRIC_LOAD1} on ${METRIC_NCPU} CPUs — system is under heavy stress."
        info "Suggested fix: toggle power profile to reduce background CPU pressure."
        if confirm "Toggle power mode now?"; then
            boost
            (( fixed++ ))
        else
            (( skipped++ ))
        fi
        echo ""
    fi

    # ── Check 4: High swap ──
    # Swap over 50% means RAM is spilling over — clean is the best we can do
    if (( METRIC_SWAP_PCT > 50 )); then
        warn "Swap usage is ${METRIC_SWAP_PCT}% — RAM is likely exhausted."
        info "Suggested fix: run cleanup to free RAM and reduce swap pressure."
        if confirm "Run cleanup now?"; then
            clean
            (( fixed++ ))
        else
            (( skipped++ ))
        fi
        echo ""
    fi

    # ── Summary ──
    if (( fixed == 0 && skipped == 0 )); then
        success "System looks healthy — no fixes needed."
    else
        (( fixed > 0 ))   && success "${fixed} fix(es) applied."
        (( skipped > 0 )) && info "${skipped} fix(es) skipped."
    fi
}
# ── Health check ───────────────────────────────────────────────────────────────
health() {
    header "System Health check"
    echo ""

    # Use shared metrics
     gather_metrics

    local issues=0

    # Load
    printf "  %-22s %s\n" "Load avg (1m):" "${METRIC_LOAD1}  (${METRIC_NCPU} CPUs)"
    if (( METRIC_LOAD_INT > METRIC_NCPU * 2 )); then
        warn "Very high load — system is under heavy stress."
        (( issues++ ))
    elif (( METRIC_LOAD_INT > METRIC_NCPU )); then
        warn "Load exceeds CPU count — may feel sluggish."
        (( issues++ ))
    else
        success "Load is healthy."
    fi

    # RAM
    printf "  %-22s %s%%\n" "RAM usage:" "$METRIC_MEM_PCT"
    if (( METRIC_MEM_PCT > 90 )); then
        warn "RAM nearly full — close some apps or run 'fml clean'."
        (( issues++ ))
    elif (( METRIC_MEM_PCT > 75 )); then
        warn "RAM usage is high."
        (( issues++ ))
    else
        success "RAM usage is healthy."
    fi

    # Disk
    printf "  %-22s %s%%\n" "Disk usage (/):" "$METRIC_DISK_PCT"
    if (( METRIC_DISK_PCT > 90 )); then
        warn "Disk nearly full — run 'fml clean' now."
        (( issues++ ))
    elif (( METRIC_DISK_PCT > 75 )); then
        warn "Disk usage is getting high — consider cleaning soon."
        (( issues++ ))
    else
        success "Disk space is fine."
    fi

    # Swap
    printf "  %-22s %s%%\n" "Swap usage:" "$METRIC_SWAP_PCT"
    if (( METRIC_SWAP_PCT > 50 )); then
        warn "Swap heavily used — system is likely slow due to low RAM."
        (( issues++ ))
    else
        success "Swap usage is fine."
    fi

    echo ""
    if (( issues == 0 )); then
        success "All checks passed — system looks healthy."
    elif (( issues == 1 )); then
        warn "1 issue found. Try 'fml clean' or 'fml boost' to help."
    else
        warn "${issues} issues found. Try 'fml clean' or 'fml boost' to help."
    fi
}

# ── Smart recommendations ──────────────────────────────────────────────────────
suggest() {
    header "System Suggestions"
    echo ""

    # Reuse shared metrics if already gathered, otherwise gather fresg
    [[ -z "${METRIC_MEM_PCT:-}" ]] && gather_metrics

    local count=0

    # RAM suggestions
    if (( METRIC_MEM_PCT > 85 )); then
        warn "RAM at ${METRIC_MEM_PCT}% — run 'fml clean' or close heavy apps like browsers."
        (( count++ ))
    elif (( METRIC_MEM_PCT > 75 )); then
        warn "RAM at ${METRIC_MEM_PCT}% — getting high, keep an eye on it."
        (( count++ ))
    fi

    # Disk suggestions
    if (( METRIC_DISK_PCT > 85 )); then
        warn "Disk at ${METRIC_DISK_PCT}% — run 'fml clean' to recover space."
        (( count++ ))
    elif (( METRIC_DISK_PCT > 75 )); then
        warn "Disk at ${METRIC_DISK_PCT}% — consider cleaning soon with 'fml clean'."
        (( count++ ))
    fi

    # Load suggestions
    if (( METRIC_LOAD_INT > METRIC_NCPU * 2 )); then
        warn "Load is very high — check 'fml top' to find what's eating CPU."
        (( count++ ))
    elif (( METRIC_LOAD_INT > METRIC_NCPU )); then
        warn "Load exceeds CPU count — system may feel slow."
        (( count++ ))
    fi

    # Swap suggestions
    if (( METRIC_SWAP_PCT > 50 )); then
        warn "Swap at ${METRIC_SWAP_PCT}% — RAM is under pressure, try 'fml clean'."
        (( count++ ))
    fi

    # CPU governor suggestion — performance mode on battery is wasteful
    local governor
    governor=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "")
    if [[ "$governor" == "performance" ]]; then
        warn "CPU governor is set to performance — run 'fml boost' to switch to power-saver if on battery."
        (( count++ ))
    fi

    echo ""
    if (( count == 0 )); then
        success "No suggestions — system looks well tuned."
    else
        info "${count} suggestion(s) above. Run 'fml fix' to address them automatically."
    fi
}
# ── Temps check ───────────────────────────────────────────────────────────────
temps() {
    header "Thermal Status" 
    
    # Added space after [ and before ], and added 'then'
    if [[ -d /sys/class/thermal/thermal_zone0 ]]; then
        for zone in /sys/class/thermal/thermal_zone*; do
            temp=$(cat "$zone/temp" 2>/dev/null)
            # Convert millidegrees Celsius to degrees
            # Using basename to get the zone name
            printf "  %-15s %d°C\n" "$(cat "$zone/type" 2>/dev/null)" "$((temp / 1000))"
        done
    else
        warn "No thermal sensors found."
    fi
}

# ── Usage ──────────────────────────────────────────────────────────────────────
usage() {
    echo -e "
${BOLD}fml${RESET} — Fix My Linux v${VERSION}
A lightweight maintenance tool for low-spec Linux machines.

${BOLD}Usage:${RESET}
  fml [COMMAND]

${BOLD}Commands:${RESET}
  status    Show load, memory, and disk usage
  top       Show top CPU and memory processes
  clean     Remove unused packages, caches, and temp files
  boost     Toggle power-saver / performance CPU mode
  health    Run a health check with warnings
  temps     Show hardware temperatures
  fix       Offers fixes for problems found
  suggest   System suggestions
  (none)    Launch the interactive menu

${BOLD}Options:${RESET}
  -h, --help       Show this help message
  -v, --version    Show version number

${BOLD}Examples:${RESET}
  fml                  Interactive menu
  fml health           Quick health check
  fml clean            Clean the system
  fml boost            Toggle CPU power mode
  fml temps           Check hardware temperatures
  fml fix             Checks your system and offers to fix each problem found
  fml suggest         System suggestions.
${BOLD}Environment:${RESET}
  NO_COLOR=1           Disable color output

Report bugs: https://github.com/Melangert/Fix-My-Laptop-FML-/issues
"
}

menu() {
while true; do
monitor() {
    trap 'echo ""; info "Exiting monitor..."; exit 0' INT
   while true; do
   clear
   echo "Last updated: $(date)" 
    status
    suggest
    sleep 2
done
}
    echo ""
    echo -e "${BOLD}  ===== fml v${VERSION} =====${RESET}"
    echo -e "  ${BOLD}Fix My Laptop${RESET}"
    echo "  ========================="
    echo "  1) Status check"
    echo "  2) Top processes"
    echo "  3) Clean system"
    echo "  4) Toggle power mode"
    echo "  5) Health check"
    echo "  6) Thermal check"
    echo "  7) Fix"
    echo "  8) Suggestions"
    echo "  9) Exit"
    echo "  ========================="
    read -rp "  Choose [1-9]: " opt
    case "$opt" in
        1) status; pause ;;
        2) topcpu; pause ;;
        3) clean;  pause ;;
        4) boost;  pause ;;
        5) health; pause ;;
        6) temps;  pause ;;
        7) fix;    pause ;;
        8) suggest; pause ;;

        9) echo ""; exit 0 ;;
        *) warn "Invalid option — enter 1 to 9." ;;
    esac
done
}

# ── Entry point ────────────────────────────────────────────────────────────────
case "${1:-}" in

    status)       status ;;
    top)          topcpu ;;
    clean)        clean ;;
    boost)        boost ;;
    health)       health ;;
    temps)        temps ;;
    fix)          fix ;;
    suggest)       suggest ;;
    -v|--version) echo "$SCRIPT_NAME $VERSION" ;;
    -h|--help)    usage ;;
    "")           menu ;;
    *)
        error "Unknown command: $1"
        echo "  Run 'fml --help' for usage."
        exit 1
        ;;
esac

monitor() {
    trap 'echo ""; info "Exiting monitor..."; exit 0' INT
   while true; do
   clear
   echo "Last updated: $(date)" 
    status
    suggest
    sleep 2
done
}
