#!/bin/bash
# fixmylaptop — lightweight Linux system maintenance tool
# https://github.com/Melangert/Fix-My-Laptop-FML-
# License: MIT

set -uo pipefail

VERSION="1.0.0-1"
SCRIPT_NAME="fixmylaptop"

# ── Color support ──────────────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ "${NO_COLOR:-}" == "" ]]; then
    RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
    CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'
else
    RED=''; YELLOW=''; GREEN=''; CYAN=''; BOLD=''; RESET=''
fi

# ── Helpers ────────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}→${RESET} $*"; }
success() { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
error()   { echo -e "${RED}✖${RESET}  $*" >&2; }
header()  { echo -e "\n${BOLD}$*${RESET}"; }

pause() {
    echo ""
    read -rp "Press Enter to continue..."
}

require_command() {
    command -v "$1" >/dev/null 2>&1
}

# Returns 0 if sudo is available and user can use it
have_sudo() {
    require_command sudo && sudo -n true 2>/dev/null
}

run_sudo() {
    if require_command sudo; then
        sudo "$@"
    else
        error "sudo not available — skipping: $*"
        return 1
    fi
}

confirm() {
    local prompt="${1:-Are you sure?}"
    local answer
    read -rp "$(echo -e "${YELLOW}?${RESET}  ${prompt} [y/N] ")" answer
    [[ "$answer" =~ ^[Yy]$ ]]
}

# ── Commands ───────────────────────────────────────────────────────────────────

status() {
    header "System Status"

    info "Load averages (1m / 5m / 15m):"
    awk '{print "   " $1 " / " $2 " / " $3}' /proc/loadavg

    info "Memory:"
    free -h | awk '
        /^Mem:/ { printf "   Used: %s / %s (%.0f%%)\n", $3, $2, $3/$2*100 }
        /^Swap:/ { if ($2 != "0") printf "   Swap: %s / %s\n", $3, $2 }
    '

    info "Disk (/):"
    df -h / | awk 'NR==2 { printf "   Used: %s / %s (%s)\n", $3, $2, $5 }'

    info "Uptime:"
    uptime -p 2>/dev/null || uptime
}

topcpu() {
    header "Top Resource-Heavy Processes"
    info "CPU:"
    ps -eo pid,comm,%cpu,%mem --sort=-%cpu 2>/dev/null | head -11 | \
        awk 'NR==1{printf "   %-8s %-20s %5s %5s\n",$1,$2,$3,$4; next}
             {printf "   %-8s %-20s %5s %5s\n",$1,$2,$3,$4}'

    info "Memory:"
    ps -eo pid,comm,%cpu,%mem --sort=-%mem 2>/dev/null | head -6 | \
        awk 'NR==1{printf "   %-8s %-20s %5s %5s\n",$1,$2,$3,$4; next}
             {printf "   %-8s %-20s %5s %5s\n",$1,$2,$3,$4}'
}

clean() {
    header "System Cleanup"
    echo "  This will remove unused packages, old logs, and user cache files."
    echo "  Your personal documents and app data are not affected."
    echo ""
    confirm "Proceed with cleanup?" || { info "Cleanup cancelled."; return 0; }

    local freed=0

    # ── Package manager cleanup ──
    if require_command apt; then
        info "Cleaning APT packages..."
        run_sudo apt-get autoremove -y -q && \
        run_sudo apt-get clean -q && \
        success "APT cleaned."
    fi

    if require_command dnf; then
        info "Cleaning DNF packages..."
        run_sudo dnf autoremove -y -q && success "DNF cleaned."
    fi

    if require_command pacman; then
        info "Cleaning Pacman cache (keeping 1 version)..."
        if require_command paccache; then
            run_sudo paccache -rk1 && success "Pacman cache trimmed."
        else
            run_sudo pacman -Sc --noconfirm && success "Pacman cache cleared."
        fi
    fi

    if require_command zypper; then
        info "Cleaning zypper packages..."
        run_sudo zypper clean -a && success "Zypper cleaned."
    fi

    # ── Flatpak / Snap orphans ──
    if require_command flatpak; then
        info "Removing unused Flatpak runtimes..."
        flatpak uninstall --unused -y 2>/dev/null && success "Flatpak cleaned."
    fi

    if require_command snap; then
        info "Removing old Snap revisions..."
        snap list --all 2>/dev/null | awk '/disabled/{print $1, $3}' | \
            while read -r snapname revision; do
                run_sudo snap remove "$snapname" --revision="$revision" 2>/dev/null
            done
        success "Snap old revisions removed."
    fi

    # ── User thumbnail cache ──
    if [[ -d "${HOME}/.cache/thumbnails" ]]; then
        info "Clearing thumbnail cache..."
        rm -rf "${HOME}/.cache/thumbnails"/* 2>/dev/null
        success "Thumbnail cache cleared."
    fi

    # ── Browser caches (optional, user-owned only) ──
    local cache_dirs=(
        "${HOME}/.cache/google-chrome/Default/Cache"
        "${HOME}/.cache/chromium/Default/Cache"
        "${HOME}/.cache/mozilla/firefox"
    )
    for d in "${cache_dirs[@]}"; do
        if [[ -d "$d" ]]; then
            info "Clearing $(basename "$(dirname "$d")") cache..."
            rm -rf "${d:?}"/* 2>/dev/null
        fi
    done

    # ── User-owned /tmp files only ──
    info "Removing your temp files from /tmp..."
    find /tmp -maxdepth 1 -user "$USER" -not -name "." \
        -exec rm -rf {} + 2>/dev/null || true
    success "Temp files cleaned."

    # ── Journal logs ──
    if require_command journalctl; then
        info "Trimming system journal (keeping 7 days)..."
        run_sudo journalctl --vacuum-time=7d 2>/dev/null && success "Journal trimmed."
    fi

    success "Cleanup complete."
}

boost() {
    header "Performance Boost"

    local method=""

    if require_command powerprofilesctl; then
        if powerprofilesctl set performance 2>/dev/null; then
            method="powerprofilesctl"
        fi
    elif require_command tuned-adm; then
        if run_sudo tuned-adm profile throughput-performance 2>/dev/null; then
            method="tuned-adm"
        fi
    elif require_command cpupower; then
        if run_sudo cpupower frequency-set -g performance 2>/dev/null; then
            method="cpupower"
        fi
    elif [[ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]]; then
        local gov
        gov=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "unknown")
        info "Current CPU governor: $gov"
        if [[ "$gov" != "performance" ]]; then
            warn "Cannot set governor automatically — try: sudo cpupower frequency-set -g performance"
        else
            success "Already running in performance mode."
        fi
        return 0
    fi

    if [[ -n "$method" ]]; then
        success "Performance mode enabled via $method."
        warn "Remember to reset to 'balanced' or 'powersave' when on battery."
    else
        warn "No CPU performance control found on this system."
        info "Your CPU likely manages performance automatically (modern kernels handle this well)."
    fi
}

health() {
    header "System Health Check"

    # Load
    local load1 load5 ncpu score=0 issues=0
    load1=$(awk '{print $1}' /proc/loadavg)
    load5=$(awk '{print $2}' /proc/loadavg)
    ncpu=$(nproc 2>/dev/null || echo 1)
    local load_int
    load_int=$(echo "$load1" | awk '{printf "%.0f", $1}')

    echo ""
    printf "  %-20s %s\n" "Load avg (1m/5m):" "${load1} / ${load5}  (${ncpu} CPUs)"
    if (( load_int > ncpu * 2 )); then
        warn "Very high load — system may be under heavy stress."
        (( issues++ ))
    elif (( load_int > ncpu )); then
        warn "Load above CPU count — may be slow."
        (( issues++ ))
    else
        success "Load looks healthy."
    fi

    # Memory
    local mem_used mem_total mem_pct
    mem_used=$(free | awk '/^Mem:/{print $3}')
    mem_total=$(free | awk '/^Mem:/{print $2}')
    if [[ -n "$mem_total" && "$mem_total" -gt 0 ]] 2>/dev/null; then
        mem_pct=$(awk "BEGIN{printf \"%.0f\", ${mem_used}/${mem_total}*100}")
        printf "  %-20s %s%%\n" "RAM usage:" "$mem_pct"
        if (( mem_pct > 90 )); then
            warn "RAM is very full — consider closing apps."
            (( issues++ ))
        elif (( mem_pct > 75 )); then
            warn "RAM usage is high."
        else
            success "Memory usage is healthy."
        fi
    else
        warn "Could not read memory info."
    fi

    # Disk
    local disk_pct
    disk_pct=$(df / | awk 'NR==2{gsub(/%/,"",$5); print $5}')
    if [[ "$disk_pct" =~ ^[0-9]+$ ]]; then
        printf "  %-20s %s%%\n" "Disk usage (/):" "$disk_pct"
        if (( disk_pct > 90 )); then
            warn "Disk is nearly full — run 'fixmylaptop clean'."
            (( issues++ ))
        elif (( disk_pct > 75 )); then
            warn "Disk usage is getting high."
        else
            success "Disk space looks fine."
        fi
    else
        warn "Could not read disk usage."
    fi

    # Swap
    local swap_used swap_total
    swap_used=$(free | awk '/^Swap:/{print $3}')
    swap_total=$(free | awk '/^Swap:/{print $2}')
    if [[ -n "$swap_total" && "$swap_total" -gt 0 ]] 2>/dev/null; then
        local swap_pct
        swap_pct=$(awk "BEGIN{printf \"%.0f\", ${swap_used}/${swap_total}*100}")
        printf "  %-20s %s%%\n" "Swap usage:" "$swap_pct"
        if (( swap_pct > 50 )); then
            warn "Swap is heavily used — system may be slow."
            (( issues++ ))
        fi
    fi

    echo ""
    if (( issues == 0 )); then
        success "All checks passed — system looks healthy."
    else
        warn "$issues issue(s) found. Run 'fixmylaptop clean' or 'fixmylaptop boost' to help."
    fi
}

usage() {
    cat <<EOF
${BOLD}Usage:${RESET} fixmylaptop [COMMAND]

A lightweight Linux system maintenance tool.

${BOLD}Commands:${RESET}
  status    Show system load, memory, and disk
  top       Show top CPU/memory processes
  clean     Remove unused packages, caches, and temp files
  boost     Enable performance CPU governor
  health    Run a health check with warnings
  (none)    Launch interactive menu

${BOLD}Options:${RESET}
  -h, --help       Show this help
  -v, --version    Show version

${BOLD}Examples:${RESET}
  fixmylaptop              # Interactive menu
  fixmylaptop health       # Quick health check
  fixmylaptop clean        # Clean the system

Report bugs at: https://github.com/Melangert/Fix-My-Laptop-FML-
EOF
}

menu() {
    while true; do
        echo ""
        echo -e "${BOLD}===== FixMyLaptop v${VERSION} =====${RESET}"
        echo "  1) Status check"
        echo "  2) Top processes"
        echo "  3) Clean system"
        echo "  4) Boost mode"
        echo "  5) Health check"
        echo "  6) Exit"
        echo -e "${BOLD}===============================${RESET}"
        read -rp "Choose option [1-6]: " opt
        case "$opt" in
            1) status;  pause ;;
            2) topcpu;  pause ;;
            3) clean;   pause ;;
            4) boost;   pause ;;
            5) health;  pause ;;
            6) exit 0 ;;
            *) warn "Invalid option — enter 1 to 6." ;;
        esac
    done
}

# ── Entry point ────────────────────────────────────────────────────────────────
case "${1:-}" in
    status)          status ;;
    top)             topcpu ;;
    clean)           clean ;;
    boost)           boost ;;
    health)          health ;;
    -v|--version)    echo "$SCRIPT_NAME $VERSION" ;;
    -h|--help)       usage ;;
    "")              menu ;;
    *)
        error "Unknown command: $1"
        echo "Run 'fixmylaptop --help' for usage."
        exit 1
        ;;
esac
